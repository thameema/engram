server:
  host: 0.0.0.0
  mcp_port: 8765
  api_port: 8766
  log_level: INFO

auth:
  api_keys:
    - key: ${ENGRAM_API_KEY}
      user_id: default
      namespaces: ["*"]
      # Fine-grained per-namespace access (optional):
      # namespace_access:
      #   - namespace: org:acme:engineering
      #     access: read_write
      #   - namespace: org:acme:finance
      #     access: read_only
      # Vault-specific access (independent of memory namespace access):
      # Keys with namespaces: ["*"] automatically get vault_admin.
      # For scoped keys, grant explicit vault permissions:
      # vault_namespaces:
      #   - namespace: org:acme:engineering
      #     access: vault_read      # can retrieve secrets
      #   - namespace: org:acme:engineering
      #     access: vault_write     # can store/rotate secrets
      #   - namespace: org:acme
      #     access: vault_admin     # can also read audit log

arcadedb:
  host: localhost          # use "arcadedb" inside Docker Compose
  port: 2480
  database: engram
  username: root
  password: ${ARCADEDB_PASSWORD}

embeddings:
  provider: local          # "local" (no API key) or "openai"
  model: all-MiniLM-L6-v2  # 384-dim, fast, runs on CPU
  # OpenAI alternative (requires pip install 'engram-core[openai-embeddings]'):
  # provider: openai
  # model: text-embedding-3-small
  # api_key: ${OPENAI_API_KEY}

runtime:
  default: api
  max_concurrent_workers: 5
  worker_timeout_s: 300
  api:
    provider: anthropic
    model: claude-sonnet-4-6
    api_key: ${ANTHROPIC_API_KEY}
  openrouter:
    model: anthropic/claude-sonnet-4-6
    api_key: ${OPENROUTER_API_KEY}

namespaces:
  default: personal:default
  definitions:
    # Personal namespace — local to this instance, never shared
    personal:default:
      owners: [default]
    # Enterprise namespace example:
    # org:acme:engineering:
    #   owners: [alice]
    #   writers: [bob, carol]
    #   readers: [*]

gateway:
  telegram:
    enabled: false
    bot_token: ${TELEGRAM_BOT_TOKEN}
    allowed_users: []
    default_namespace: personal:default
  whatsapp:
    enabled: false
    evolution_api_url: http://localhost:8080
    evolution_api_key: ${EVOLUTION_API_KEY}
    default_namespace: personal:default

vault:
  enabled: true
  # Scan memory writes for credential patterns and redact them automatically
  detect_in_memory: true
  # Write an immutable audit record on every vault access
  audit_log: true
  kms:
    # Local mode (dev / single-server): key derived from ENGRAM_VAULT_KEY env var.
    # Generate a key: python -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
    provider: local
    # Production — Azure Key Vault (pip install azure-keyvault-keys azure-identity):
    # provider: azure_keyvault
    # key_url: https://my-vault.vault.azure.net/keys/engram-kek/version
    # Production — AWS KMS (pip install boto3):
    # provider: aws_kms
    # key_url: arn:aws:kms:us-east-1:123456789012:key/mrk-abc123

learning:
  enabled: true
  episodic:
    enabled: true
    retention_days: 365
  feedback:
    correction_detection: true
    feedback_endpoint: true
  reflection:
    enabled: true
    schedule: "0 2 * * *"
    trigger_on_correction: true
    min_episodes_per_run: 5
    lookback_days: 7
    model: claude-haiku-4-5-20251001
  skill_extraction:
    enabled: true
    quality_threshold: 0.8
    similarity_threshold: 0.92
  heuristic_decay:
    enabled: true
    schedule: "0 3 * * 0"
    inactive_days_before_decay: 30
    decay_rate: 0.9
  quality_routing:
    enabled: true
    min_samples: 10
    quality_threshold: 0.6
