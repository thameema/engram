#!/usr/bin/env bash
# engram — start/stop/status the engram server
#
# Usage:
#   engram start
#   engram stop
#   engram restart
#   engram status
#   engram logs [engram|neo4j|qdrant]
#   engram config
#
# Environment overrides:
#   ENGRAM_DIR     Installation directory (default: ~/.engram)
#   ENGRAM_CONFIG  Config file path       (default: $ENGRAM_DIR/engram.yaml)

set -euo pipefail

# ─── Config ───────────────────────────────────────────────────────────────────
ENGRAM_DIR="${ENGRAM_DIR:-$HOME/.engram}"
ENGRAM_CONFIG="${ENGRAM_CONFIG:-${ENGRAM_DIR}/engram.yaml}"
ENGRAM_LOG="${ENGRAM_DIR}/logs/engram.log"
ENGRAM_PID="${ENGRAM_DIR}/logs/engram.pid"
MCP_PORT="${MCP_PORT:-8765}"
API_PORT="${API_PORT:-8766}"

# ─── Colors ───────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ─── Helpers ──────────────────────────────────────────────────────────────────
info()    { echo -e "${CYAN}  -->${NC} $*"; }
success() { echo -e "${GREEN}  [ok]${NC} $*"; }
warn()    { echo -e "${YELLOW}  [!]${NC} $*"; }
error()   { echo -e "${RED}  [error]${NC} $*" >&2; }
die()     { error "$*"; exit 1; }
bold()    { echo -e "${BOLD}$*${NC}"; }

# ─── Prerequisite check ───────────────────────────────────────────────────────
check_installed() {
  if [ ! -f "${ENGRAM_DIR}/.env" ]; then
    die "engram is not installed. Run the installer first:
  curl -fsSL https://raw.githubusercontent.com/yourusername/engram/main/install.sh | bash"
  fi
  if [ ! -f "${ENGRAM_DIR}/docker-compose.yml" ]; then
    die "docker-compose.yml not found at ${ENGRAM_DIR}. Re-run the installer."
  fi
}

# ─── Docker Compose detection ─────────────────────────────────────────────────
detect_compose() {
  if docker compose version &>/dev/null 2>&1; then
    DOCKER_COMPOSE="docker compose"
  elif command -v docker-compose &>/dev/null 2>&1; then
    DOCKER_COMPOSE="docker-compose"
  else
    die "Docker Compose not found. Install it and retry."
  fi
}

# ─── Load .env ────────────────────────────────────────────────────────────────
load_env() {
  if [ -f "${ENGRAM_DIR}/.env" ]; then
    set -a
    # shellcheck disable=SC1090
    source "${ENGRAM_DIR}/.env"
    set +a
  fi
}

# ─── Start ────────────────────────────────────────────────────────────────────
cmd_start() {
  check_installed
  detect_compose
  load_env

  echo ""
  bold "Starting engram..."
  echo ""

  # Start Docker containers
  info "Starting Neo4j and Qdrant containers..."
  (cd "${ENGRAM_DIR}" && $DOCKER_COMPOSE up -d) 2>&1 | grep -vE "^#|WARNING"

  # Wait for Neo4j to be healthy
  info "Waiting for Neo4j to be ready..."
  local attempts=0
  while ! (cd "${ENGRAM_DIR}" && $DOCKER_COMPOSE ps 2>/dev/null | grep -E "neo4j.*healthy" &>/dev/null); do
    sleep 3
    attempts=$((attempts + 1))
    echo -ne "\r  ${CYAN}-->${NC} Waiting for Neo4j... ${attempts}s"
    if [ $attempts -ge 40 ]; then
      echo ""
      error "Neo4j did not become healthy after 120s."
      echo "  Check logs: engram logs neo4j"
      exit 1
    fi
  done
  echo ""
  success "Neo4j is healthy."

  # Wait for Qdrant
  local qattempts=0
  while ! curl -sf "http://localhost:6333/healthz" &>/dev/null; do
    sleep 2
    qattempts=$((qattempts + 1))
    if [ $qattempts -ge 15 ]; then
      warn "Qdrant health check timed out — continuing anyway."
      break
    fi
  done
  success "Qdrant is ready."

  # Start Python server
  if [ -f "${ENGRAM_PID}" ] && kill -0 "$(cat "${ENGRAM_PID}")" 2>/dev/null; then
    warn "engram server already running (PID $(cat "${ENGRAM_PID}"))"
  else
    info "Starting engram Python server..."
    mkdir -p "${ENGRAM_DIR}/logs"

    nohup engram-server \
      --config "${ENGRAM_CONFIG}" \
      --mcp-port "${MCP_PORT}" \
      --api-port "${API_PORT}" \
      >> "${ENGRAM_LOG}" 2>&1 &
    echo $! > "${ENGRAM_PID}"

    # Brief wait to confirm it stays up
    sleep 2
    if kill -0 "$(cat "${ENGRAM_PID}")" 2>/dev/null; then
      success "engram server started (PID $(cat "${ENGRAM_PID}"))"
    else
      error "engram server exited immediately. Check: ${ENGRAM_LOG}"
      tail -20 "${ENGRAM_LOG}" 2>/dev/null || true
      rm -f "${ENGRAM_PID}"
      exit 1
    fi
  fi

  # Health check with retry
  local hattempts=0
  while ! curl -sf "http://localhost:${API_PORT}/api/v1/health" &>/dev/null; do
    sleep 2
    hattempts=$((hattempts + 1))
    if [ $hattempts -ge 10 ]; then
      warn "API health check timed out — server may still be initializing."
      break
    fi
  done

  echo ""
  echo -e "${BOLD}${GREEN}engram is running!${NC}"
  echo ""
  echo -e "  MCP SSE endpoint : ${BOLD}http://localhost:${MCP_PORT}/sse${NC}"
  echo -e "  REST API          : ${BOLD}http://localhost:${API_PORT}/api/v1${NC}"
  echo -e "  Neo4j browser     : ${BOLD}http://localhost:7474${NC}"
  echo -e "  Data directory    : ${BOLD}${ENGRAM_DIR}${NC}"
  echo ""
  echo -e "  ${DIM}Claude Code MCP config:${NC}"
  local api_key
  api_key="${ENGRAM_API_KEY:-$(grep ENGRAM_API_KEY "${ENGRAM_DIR}/.env" 2>/dev/null | cut -d= -f2 || echo 'your-key')}"
  echo ""
  cat <<JSON
  {
    "mcpServers": {
      "engram": {
        "url": "http://localhost:${MCP_PORT}/sse",
        "apiKey": "${api_key}"
      }
    }
  }
JSON
  echo ""
}

# ─── Stop ─────────────────────────────────────────────────────────────────────
cmd_stop() {
  check_installed
  detect_compose
  echo ""
  bold "Stopping engram..."
  echo ""

  # Stop Python server
  if [ -f "${ENGRAM_PID}" ]; then
    local pid
    pid="$(cat "${ENGRAM_PID}")"
    if kill -0 "$pid" 2>/dev/null; then
      info "Stopping engram server (PID ${pid})..."
      kill "$pid" 2>/dev/null || true
      # Wait up to 10s for clean shutdown
      local i=0
      while kill -0 "$pid" 2>/dev/null && [ $i -lt 10 ]; do
        sleep 1
        i=$((i + 1))
      done
      kill -9 "$pid" 2>/dev/null || true
      success "engram server stopped."
    else
      warn "engram server was not running."
    fi
    rm -f "${ENGRAM_PID}"
  else
    warn "engram server PID file not found."
  fi

  # Stop Docker
  info "Stopping Docker containers..."
  (cd "${ENGRAM_DIR}" && $DOCKER_COMPOSE down) 2>&1 | tail -5
  success "Docker containers stopped."
  echo ""
}

# ─── Restart ──────────────────────────────────────────────────────────────────
cmd_restart() {
  cmd_stop
  cmd_start
}

# ─── Status ───────────────────────────────────────────────────────────────────
cmd_status() {
  detect_compose
  echo ""
  bold "engram status"
  echo ""

  # Docker containers
  echo -e "  ${BOLD}Docker containers:${NC}"
  if (cd "${ENGRAM_DIR}" && $DOCKER_COMPOSE ps 2>/dev/null | grep -qE "neo4j|qdrant"); then
    (cd "${ENGRAM_DIR}" && $DOCKER_COMPOSE ps 2>/dev/null) | \
      grep -E "neo4j|qdrant" | \
      awk '{printf "    %-35s %s\n", $1, $3}' 2>/dev/null || \
      (cd "${ENGRAM_DIR}" && $DOCKER_COMPOSE ps 2>/dev/null | tail -n +2 | head -5)
  else
    echo -e "    ${RED}No containers running${NC}"
  fi

  echo ""

  # Python server
  echo -e "  ${BOLD}Python server:${NC}"
  if [ -f "${ENGRAM_PID}" ] && kill -0 "$(cat "${ENGRAM_PID}")" 2>/dev/null; then
    local pid
    pid="$(cat "${ENGRAM_PID}")"
    echo -e "    ${GREEN}Running${NC} (PID ${pid})"
    if curl -sf "http://localhost:${API_PORT}/api/v1/health" &>/dev/null; then
      local health
      health="$(curl -sf "http://localhost:${API_PORT}/api/v1/health" 2>/dev/null | \
        python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('status','healthy'))" 2>/dev/null || echo "healthy")"
      echo -e "    ${GREEN}Health: ${health}${NC}"
    else
      echo -e "    ${YELLOW}Process running but health endpoint not responding${NC}"
    fi
  else
    echo -e "    ${RED}Not running${NC}"
    [ -f "${ENGRAM_PID}" ] && rm -f "${ENGRAM_PID}"
  fi

  echo ""

  # Endpoints
  echo -e "  ${BOLD}Endpoints:${NC}"
  for url in \
    "MCP SSE    http://localhost:${MCP_PORT}/sse" \
    "REST API   http://localhost:${API_PORT}/api/v1" \
    "Neo4j      http://localhost:7474" \
    "Qdrant     http://localhost:6333"
  do
    local label url_val
    label="$(echo "$url" | awk '{print $1}')"
    url_val="$(echo "$url" | awk '{print $2}')"
    if curl -sf --max-time 2 "${url_val}" &>/dev/null || \
       curl -sf --max-time 2 "${url_val}/healthz" &>/dev/null; then
      echo -e "    ${GREEN}UP${NC}    ${label}  ${DIM}${url_val}${NC}"
    else
      echo -e "    ${RED}DOWN${NC}  ${label}  ${DIM}${url_val}${NC}"
    fi
  done

  echo ""
  echo -e "  ${DIM}Data: ${ENGRAM_DIR}${NC}"
  echo ""
}

# ─── Logs ─────────────────────────────────────────────────────────────────────
cmd_logs() {
  detect_compose
  local target="${1:-engram}"
  case "$target" in
    neo4j)
      info "Tailing Neo4j logs (Ctrl-C to stop)..."
      (cd "${ENGRAM_DIR}" && $DOCKER_COMPOSE logs -f neo4j)
      ;;
    qdrant)
      info "Tailing Qdrant logs (Ctrl-C to stop)..."
      (cd "${ENGRAM_DIR}" && $DOCKER_COMPOSE logs -f qdrant)
      ;;
    engram|server|"")
      if [ -f "${ENGRAM_LOG}" ]; then
        info "Tailing engram server logs (Ctrl-C to stop)..."
        tail -f "${ENGRAM_LOG}"
      else
        warn "No log file found at: ${ENGRAM_LOG}"
        echo "  Start engram first: engram start"
      fi
      ;;
    all)
      info "Tailing all Docker logs + server log..."
      (cd "${ENGRAM_DIR}" && $DOCKER_COMPOSE logs -f) &
      [ -f "${ENGRAM_LOG}" ] && tail -f "${ENGRAM_LOG}" &
      wait
      ;;
    *)
      error "Unknown log target: ${target}"
      echo "  Options: engram, neo4j, qdrant, all"
      exit 1
      ;;
  esac
}

# ─── Config ───────────────────────────────────────────────────────────────────
cmd_config() {
  if [ -f "${ENGRAM_CONFIG}" ]; then
    cat "${ENGRAM_CONFIG}"
  else
    error "Config not found at: ${ENGRAM_CONFIG}"
    exit 1
  fi
}

# ─── Help ─────────────────────────────────────────────────────────────────────
cmd_help() {
  echo ""
  echo -e "  ${BOLD}engram${NC} — persistent memory for LLM workflows"
  echo ""
  echo "  Usage: engram <command> [options]"
  echo ""
  echo "  Commands:"
  printf "    %-12s %s\n" "start"    "Start all services (Neo4j, Qdrant, Python server)"
  printf "    %-12s %s\n" "stop"     "Stop all services"
  printf "    %-12s %s\n" "restart"  "Restart all services"
  printf "    %-12s %s\n" "status"   "Show health and running status"
  printf "    %-12s %s\n" "logs"     "Tail logs: engram logs [engram|neo4j|qdrant|all]"
  printf "    %-12s %s\n" "config"   "Print engram.yaml"
  echo ""
  echo "  Environment:"
  printf "    %-20s %s\n" "ENGRAM_DIR"    "Installation directory (default: ~/.engram)"
  printf "    %-20s %s\n" "ENGRAM_CONFIG" "Config file path"
  printf "    %-20s %s\n" "MCP_PORT"      "MCP SSE port (default: 8765)"
  printf "    %-20s %s\n" "API_PORT"      "REST API port (default: 8766)"
  echo ""
  echo -e "  ${DIM}Data: ${ENGRAM_DIR}${NC}"
  echo ""
}

# ─── Dispatch ─────────────────────────────────────────────────────────────────
case "${1:-}" in
  start)    cmd_start ;;
  stop)     cmd_stop ;;
  restart)  cmd_restart ;;
  status)   cmd_status ;;
  logs)     cmd_logs "${2:-}" ;;
  config)   cmd_config ;;
  -h|--help|help|"") cmd_help ;;
  *)
    error "Unknown command: $1"
    cmd_help
    exit 1
    ;;
esac
