server:
  host: 0.0.0.0
  mcp_port: 8765
  api_port: 8766
  log_level: INFO

auth:
  # open_mode: skip all authentication — suitable for local single-user installs only.
  # Set to false (or remove) when exposing engram to a network or team.
  open_mode: false

  api_keys:
    # Admin key — full read/write access to all namespaces.
    # user_id must match the client's default namespace prefix
    # (ENGRAM_DEFAULT_NS in ~/.claude/hooks/engram.env defaults to 'personal:me',
    # so user_id 'me' auto-creates the matching 'personal:me' namespace).
    - key: ${ENGRAM_API_KEY}
      user_id: me
      namespaces: ["*"]
      read_only: false        # default; omit or set false for read-write
      # Fine-grained per-namespace access (optional):

    # Read-only key example — safe to share with web apps or external integrations
    # - key: ${ENGRAM_READONLY_KEY}
    #   user_id: webapp
    #   namespaces: ["personal:default"]
    #   read_only: true       # prevents writes, deletes, and vault mutations

    # Scoped team key example
    # - key: ${ENGRAM_TEAM_KEY}
    #   user_id: team-alice
    #   namespaces: ["org:myteam:*"]
    #   read_only: false
      # Fine-grained per-namespace access (optional):
      # namespace_access:
      #   - namespace: org:acme:engineering
      #     access: read_write
      #   - namespace: org:acme:finance
      #     access: read_only
      # Vault-specific access (independent of memory namespace access):
      # Keys with namespaces: ["*"] automatically get vault_admin.
      # For scoped keys, grant explicit vault permissions:
      # vault_namespaces:
      #   - namespace: org:acme:engineering
      #     access: vault_read      # can retrieve secrets
      #   - namespace: org:acme:engineering
      #     access: vault_write     # can store/rotate secrets
      #   - namespace: org:acme
      #     access: vault_admin     # can also read audit log

arcadedb:
  # In Docker Compose, ARCADEDB_HOST is set to "arcadedb" (the service name).
  # For a non-Docker install, leave ARCADEDB_HOST unset → falls back to localhost.
  host: ${ARCADEDB_HOST:-localhost}
  port: ${ARCADEDB_PORT:-2480}
  database: engram
  username: root
  password: ${ARCADEDB_PASSWORD}

embeddings:
  # ⚠️  IMPORTANT: do not change provider/model after writing memories.
  #     Different models produce vectors in incompatible spaces (different
  #     dimensions, different embedding spaces). Switching backend requires
  #     re-encoding every memory via tools/reembed.py — search is broken
  #     until that migration finishes. Only one direction is scripted today:
  #     local → openai. Pick carefully.
  #
  # Provider is driven by ENGRAM_EMBED_MODE in .env, so the installer can
  # set it without editing this file. Recognised values:
  #   auto    — auto-detect from API keys: OpenAI if OPENAI_API_KEY set,
  #             else Voyage if VOYAGE_API_KEY set, else local
  #   openai  — text-embedding-3-small (1536-dim, requires OPENAI_API_KEY)
  #   online  — alias for openai
  #   voyage  — Voyage AI voyage-3-lite (512-dim, requires VOYAGE_API_KEY)
  #   local   — sentence-transformers all-MiniLM-L6-v2 (384-dim, fully offline,
  #             requires the engram image built with EMBED_MODE=local — adds ~2 GB)
  provider: ${ENGRAM_EMBED_MODE:-auto}
  # Model is auto-selected per provider (text-embedding-3-small for openai,
  # all-MiniLM-L6-v2 for local). Override here only if you need a specific model.
  # model: BAAI/bge-large-en-v1.5      # higher-quality local (~1.3 GB)
  # model: text-embedding-3-large      # higher-quality OpenAI (3072-dim)
  api_key: ${OPENAI_API_KEY:-}

vector_backend:
  # "arcadedb" (default) — Python-layer cosine similarity, good up to ~100K memories
  # "qdrant"  — HNSW ANN via Qdrant, ~3 ms search regardless of corpus size
  #             Requires: docker compose --profile qdrant up -d
  #             Backfill:  python3 tools/migrate_to_qdrant.py
  backend: ${ENGRAM_VECTOR_BACKEND:-arcadedb}
  qdrant:
    url: ${QDRANT_URL:-http://qdrant:6333}
    api_key: ${QDRANT_API_KEY:-}
    collection: engram_memories

runtime:
  default: api
  max_concurrent_workers: 5
  worker_timeout_s: 300
  api:
    provider: anthropic
    model: claude-sonnet-4-6
    api_key: ${ANTHROPIC_API_KEY}
  openrouter:
    model: anthropic/claude-sonnet-4-6
    api_key: ${OPENROUTER_API_KEY}

namespaces:
  default: personal:default
  definitions:
    # Personal namespace — local to this instance, never shared
    personal:default:
      owners: [default]
    # Enterprise namespace example:
    # org:acme:engineering:
    #   owners: [alice]
    #   writers: [bob, carol]
    #   readers: [*]

gateway:
  telegram:
    enabled: false
    bot_token: ${TELEGRAM_BOT_TOKEN}
    allowed_users: []
    default_namespace: personal:default
  whatsapp:
    enabled: false
    evolution_api_url: http://localhost:8080
    evolution_api_key: ${EVOLUTION_API_KEY}
    default_namespace: personal:default

vault:
  enabled: true
  # Scan memory writes for credential patterns and redact them automatically
  detect_in_memory: true
  # Write an immutable audit record on every vault access
  audit_log: true
  kms:
    # Local mode (dev / single-server): key derived from ENGRAM_VAULT_KEY env var.
    # Generate a key: python -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
    provider: local
    # Production — Azure Key Vault (pip install azure-keyvault-keys azure-identity):
    # provider: azure_keyvault
    # key_url: https://my-vault.vault.azure.net/keys/engram-kek/version
    # Production — AWS KMS (pip install boto3):
    # provider: aws_kms
    # key_url: arn:aws:kms:us-east-1:123456789012:key/mrk-abc123

learning:
  enabled: true
  episodic:
    enabled: true
    retention_days: 365
  feedback:
    correction_detection: true
    feedback_endpoint: true
  reflection:
    enabled: true
    schedule: "0 2 * * *"
    trigger_on_correction: true
    min_episodes_per_run: 5
    lookback_days: 7
    model: claude-haiku-4-5-20251001
  skill_extraction:
    enabled: true
    quality_threshold: 0.8
    similarity_threshold: 0.92
  heuristic_decay:
    enabled: true
    schedule: "0 3 * * 0"
    inactive_days_before_decay: 30
    decay_rate: 0.9
  quality_routing:
    enabled: true
    min_samples: 10
    quality_threshold: 0.6
