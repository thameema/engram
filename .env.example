# Copy to .env and fill in your values
# ─────────────────────────────────────
# Required
ARCADEDB_PASSWORD=change-me-strong-password
ENGRAM_API_KEY=engram-change-me

# ─── Data directory ──────────────────────────────────────────────────────────
# All engram data (ArcadeDB, API keys, tasks, learning) lives under one folder.
# Default: ~/.engram — override here if you want a different location.
# Structure created automatically:
#   $ENGRAM_DATA_DIR/arcadedb/   ← main memory database (ArcadeDB)
#   $ENGRAM_DATA_DIR/keys.db     ← dynamically created API keys
#   $ENGRAM_DATA_DIR/tasks.db    ← orchestrator task history
#   $ENGRAM_DATA_DIR/learning.db ← learning feedback data
# ENGRAM_DATA_DIR=~/.engram

# Vault — secrets encryption key (local KMS mode)
# Generate with: python -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# This is a SERVICE key — hold it in your secrets manager or CI/CD, not in .env for production.
# Team members access the vault via their API keys (vault_namespaces permissions), not this key.
# If using Azure Key Vault or AWS KMS, set kms.provider in engram.yaml instead and leave this blank.
ENGRAM_VAULT_KEY=

# LLM providers (at least one required for agent workers)
ANTHROPIC_API_KEY=sk-ant-...

# ─── Embedding mode ──────────────────────────────────────────────────────────
# Choosing a mode — accuracy vs cost vs privacy:
#
#   auto   (default) — picks best available provider based on which API keys are set:
#                      OPENAI_API_KEY → openai | OPENROUTER_API_KEY → openrouter
#                      VOYAGE_API_KEY → voyage  | none → local (sentence-transformers)
#
#   openai           — text-embedding-3-small, 1536-dim, state-of-the-art accuracy
#                      Cost: ~$0.02/1M tokens ≈ pennies/month for personal memory volumes
#                      Requires: OPENAI_API_KEY
#
#   openrouter       — same as openai but routed via OpenRouter (same key as LLM workers)
#                      Requires: OPENROUTER_API_KEY
#
#   voyage           — Voyage AI voyage-3-lite, 512-dim, fast
#                      Requires: VOYAGE_API_KEY
#
#   local            — sentence-transformers all-MiniLM-L6-v2, 384-dim, fully offline
#                      No API key needed. 100% private. Docker image is ~2 GB larger.
#                      Rebuild required after switching: docker-compose up engram --build -d
#
# ⚠ WARNING: Do NOT switch embedding modes after writing memories.
#   Vectors from different models are incompatible (different dimensions and
#   embedding spaces). Switching will break vector search on existing memories.
#   If you need to switch, wipe the ArcadeDB volume first:
#     docker-compose down -v && docker-compose up -d
#
ENGRAM_EMBED_MODE=auto

# Optional — only needed if you want to force openai provider for embeddings
# OPENAI_API_KEY=sk-...

# Optional — only needed if you switch to provider: voyage in engram.yaml
# VOYAGE_API_KEY=pa-...

# Optional
OPENROUTER_API_KEY=sk-or-...

# Gateways (optional)
# Step 1: Get a bot token from @BotFather on Telegram
# Step 2: Get your user ID from @userinfobot on Telegram
# Step 3: Set these three vars and restart Docker
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=              # from @BotFather
TELEGRAM_ALLOWED_USERS=          # your numeric user ID from @userinfobot (comma-separated for multiple)

# WhatsApp via Evolution API (optional)
EVOLUTION_API_KEY=change-me
