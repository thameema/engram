# Copy to .env and fill in your values
# ─────────────────────────────────────
# Required
ARCADEDB_PASSWORD=change-me-strong-password
ENGRAM_API_KEY=engram-change-me

# Vault — secrets encryption key (local KMS mode)
# Generate with: python -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# This is a SERVICE key — hold it in your secrets manager or CI/CD, not in .env for production.
# Team members access the vault via their API keys (vault_namespaces permissions), not this key.
# If using Azure Key Vault or AWS KMS, set kms.provider in engram.yaml instead and leave this blank.
ENGRAM_VAULT_KEY=

# LLM providers (at least one required for agent workers)
ANTHROPIC_API_KEY=sk-ant-...

# Optional — only needed if embeddings.provider: openai
# OPENAI_API_KEY=sk-...

# Optional
OPENROUTER_API_KEY=sk-or-...

# Gateways (optional)
TELEGRAM_BOT_TOKEN=              # get from @BotFather
TELEGRAM_ALLOWED_USERS=          # comma-separated Telegram user IDs

# WhatsApp via Evolution API (optional)
EVOLUTION_API_KEY=change-me
