# .env.test — E2E test stack environment
#
# Used with: docker compose -f docker-compose.yml -f docker-compose.test.yml \
#                            --env-file .env.test -p engram-test up -d
#
# Safe to commit — no real secrets here.
# Inherits ANTHROPIC_API_KEY / OPENAI_API_KEY from your shell for embeddings.

# ── Isolation ────────────────────────────────────────────────────────────────
# NOTE: ~ is NOT expanded by docker-compose --env-file.
# ENGRAM_DATA_DIR is injected as an absolute path by the Makefile:
#   ENGRAM_DATA_DIR=$(HOME)/.engram-test make e2e-up
# Do NOT set it here — the Makefile overrides it correctly.

# ── Auth (test values — not your production keys) ────────────────────────────
ARCADEDB_PASSWORD=engram-test
ENGRAM_API_KEY=test-api-key-e2e

# ── Embedding mode — inherit from shell or default to auto ───────────────────
# Set ENGRAM_EMBED_MODE=local before running if you have no API keys
# ENGRAM_EMBED_MODE=local

# ── Disable optional gateways for tests ─────────────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

# ── Vault (test key — not your production vault key) ────────────────────────
# Generate with: python -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
ENGRAM_VAULT_KEY=dGVzdC12YXVsdC1rZXktZm9yLWUyZS10ZXN0cy1vbmx5LQ==
